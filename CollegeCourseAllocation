def assign_wave(priority_column):
    """
    Assign students for a given priority (fall_1, fall_2, fall_3)
    """
    global students, course_remaining

    for i, row in students.iterrows():
        remaining_slots = row['fall_course_num'] - len(row['assigned_courses'])
        if remaining_slots <= 0:
            continue  # student already full

        course = row[priority_column]
        if pd.isna(course):
            continue

        if course not in row['assigned_courses'] and course_remaining[course] > 0:
            students.at[i, 'assigned_courses'].append(course)
            course_remaining[course] -= 1


