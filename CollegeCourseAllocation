# --------------------------------
# 2. Wave assignment function
# --------------------------------
def assign_wave(priority_column):
    """
    Assign students for a given priority (spring_1, spring_2, spring_3)
    """
    global students_spring, spring_remaining

    apps = []

    for i, row in students_spring.iterrows():
        remaining_slots = row['Spring_Must_Have'] - len(row['assigned_courses'])
        if remaining_slots <= 0:
            continue
        if pd.isna(row[priority_column]):
            continue

        apps.append({
            'id': row['id'],
            'course': row[priority_column],
            'percentile': row['percentile']
        })

    apps_df = pd.DataFrame(apps)
    if apps_df.empty:
        return

    # Assign students per course
    for course, group in apps_df.groupby('course'):
        available = spring_remaining[course]
        if available <= 0:
            continue

        sorted_group = group.sort_values('percentile')
        winners = sorted_group.head(available)

        for student_id in winners['id']:
            idx = students_spring.index[students_spring['id'] == student_id][0]
            if course not in students_spring.at[idx, 'assigned_courses']:
                students_spring.at[idx, 'assigned_courses'].append(course)
                spring_remaining[course] -= 1

